      <aliases enabled='yes' />
      <column caption='Average Investment Per Deal' datatype='real' name='[Calculation_0723762566266880]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Pivot Field Values])&#13;&#10;/&#13;&#10;COUNTD(&#13;&#10;IF [Pivot Field Values] &gt; 0&#13;&#10;THEN [Startup Name]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Deal Conversion Rate (%)' datatype='real' name='[Calculation_1370549944287232]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Accepted Offer]) / COUNT([Pitch Number])' />
      </column>
      <column caption='Total Amount Invested (₹ Cr)' datatype='real' name='[Calculation_1370549945311233]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(SUM([Total Deal Amount]),2)' />
      </column>
      <column caption='Average Valuation Requested' datatype='real' name='[Calculation_1370549945843714]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(AVG([Valuation Requested]),0)' />
      </column>
      <column caption='Average Deal Valuation' datatype='real' name='[Calculation_1370549946429444]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;IF [Accepted Offer]=1&#13;&#10;THEN [Deal Valuation]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Average Equity Given' datatype='real' name='[Calculation_1370549946843141]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;IF [Accepted Offer]=1&#13;&#10;THEN [Total Deal Equity]&#13;&#10;END&#13;&#10;)' />
      </column>
